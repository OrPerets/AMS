# Production Environment Variables
# Copy this file to .env.production and update the values

# Docker Configuration
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters

# Frontend Configuration
NEXT_PUBLIC_API_BASE=https://your-backend-domain.com

# Optional: Email Configuration (if using email features)
# SENDGRID_API_KEY=your-sendgrid-api-key
# FROM_EMAIL=noreply@yourdomain.com

# Optional: SMS Configuration (if using SMS features)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Optional: AWS Configuration (if using AWS services)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=your-aws-region
# AWS_S3_BUCKET=your-s3-bucket-name
