# API Configuration
# For development: NEXT_PUBLIC_API_BASE="http://localhost:3000"
# For production: NEXT_PUBLIC_API_BASE="https://ams-backend-production-fb77.up.railway.app"
NEXT_PUBLIC_API_BASE="https://ams-backend-production-fb77.up.railway.app"

# Application Configuration
NEXT_PUBLIC_APP_NAME="AMS - Asset Management System"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Environment
NODE_ENV="development"

# Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=""

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
NEXT_PUBLIC_ENABLE_DEBUG="true"
