  ],
  "overrides": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@nestjs/common": "11.1.16",
    "@nestjs/core": "11.1.16",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/platform-socket.io": "11.1.16",
    "@nestjs/websockets": "11.1.16",
    "@sendgrid/mail": "^8.1.6",
    "@tailwindcss/oxide": {
      "tar": "7.5.10"
    },
    "axios": "1.13.6",
    "class-validator": {
      "validator": "13.15.26"
    },
    "glob": {
      "minimatch": "3.1.4"
    },
    "readdir-glob": {
      "minimatch": "5.1.8"
    },
    "ts-node": {
      "diff": "4.0.4"
    },
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "3.14.2"
    },
    "diff": "4.0.4",
    "fast-xml-parser": "5.4.2",
    "fsevents": "2.3.2",
    "minimatch": "10.2.4",
    "next": "15.5.10",
    "tar": "7.5.10",
    "validator": "13.15.26"
  },
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm --workspace apps/backend run build:prod && npm --workspace apps/frontend run build",
    "start": "npm --workspace apps/backend run start:prod",
    "start:prod": "npm --workspace apps/backend run start:prod",
    "test": "echo 'No tests yet'",
    "db:reset": "npm --workspace apps/backend run prisma:reset",
    "seed:test": "SEED_SCALE=small npm --workspace apps/backend run prisma:seed",
    "db:deploy": "npm --workspace apps/backend run prisma:deploy",
    "db:seed": "npm --workspace apps/backend run prisma:seed",
    "db:seed:prod": "npm --workspace apps/backend run prisma:seed:prod"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "prisma": "6.16.1"
  },
  "dependencies": {
    "@nestjs/common": "11.1.16",
    "@nestjs/core": "11.1.16",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/platform-socket.io": "11.1.16",
    "@nestjs/websockets": "11.1.16",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "next": "15.5.10"
  }
