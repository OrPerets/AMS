{
  "name": "@amit-pms/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3001 next dev",
    "build": "next build",
    "start": "mkdir -p .next/standalone/apps/frontend/.next && rm -rf .next/standalone/apps/frontend/.next/static .next/standalone/apps/frontend/public && cp -R .next/static .next/standalone/apps/frontend/.next/static && cp -R public .next/standalone/apps/frontend/public && HOSTNAME=0.0.0.0 PORT=${PORT:-3001} node .next/standalone/apps/frontend/server.js",
    "start:prod": "npm run start",
    "test:e2e": "playwright test",
    "test:e2e:qa": "playwright test --workers=1 e2e/qa-*.spec.ts",
    "test:e2e:a11y": "playwright test --workers=1 e2e/qa-sprint-7-a11y-audit.spec.ts",
    "test:e2e:visual": "playwright test --workers=1 e2e/qa-sprint-7-visual-regression.spec.ts",
    "test:e2e:perf": "playwright test --workers=1 e2e/qa-sprint-7-performance.spec.ts",
    "test:e2e:rtl-dark": "playwright test --workers=1 e2e/qa-sprint-7-rtl-dark-gates.spec.ts",
    "test:e2e:sprint-7": "playwright test --workers=1 e2e/qa-sprint-7-*.spec.ts",
    "test:e2e:sprint-8": "playwright test --workers=1 e2e/qa-sprint-8*.spec.ts",
    "test:visual:update": "playwright test --workers=1 --update-snapshots e2e/qa-sprint-7-visual-regression.spec.ts"
  },
  "dependencies": {
    "@heroui/react": "^2.8.10",
    "@heroui/theme": "^2.4.26",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.541.0",
    "next": "15.5.10",
    "next-intl": "^4.8.3",
    "react": "18.2.0",
    "react-day-picker": "^9.9.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.62.0",
    "react-intersection-observer": "^9.16.0",
    "react-type-animation": "^3.2.0",
    "recharts": "^3.1.2",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "typescript": "^5.0.0"
  }
}
