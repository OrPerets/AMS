datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PM
  TECH
  RESIDENT
  ACCOUNTANT
  MASTER
}

enum MaintenanceCategory {
  GENERAL
  HVAC
  ELECTRICAL
  PLUMBING
  SAFETY
  LANDSCAPING
  ELEVATORS
}

enum MaintenanceType {
  PREVENTIVE
  INSPECTION
  CORRECTIVE
  EMERGENCY
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketSeverity {
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum WorkOrderStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  INVOICED
}

enum BudgetStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  STAFF
  ADMINISTRATION
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CodeType {
  ENTRANCE      // Main door code
  SERVICE       // Service entrance
  ELEVATOR      // Elevator code
  GATE          // Gate code
  PARKING       // Parking barrier
  WIFI          // WiFi password
  ALARM         // Alarm system
  OTHER         // Other codes
}

enum VoteType {
  YES_NO          // Simple yes/no vote
  MULTIPLE_CHOICE // Choose one option
  RATING          // Rate 1-5 stars
}

enum ScheduleStatus {
  DRAFT       // Being created
  PUBLISHED   // Visible to assignees
  IN_PROGRESS // Work started
  COMPLETED   // All tasks done
  CANCELLED   // Schedule cancelled
}

enum TaskType {
  MAINTENANCE     // Regular maintenance
  INSPECTION      // Inspection rounds
  REPAIR          // Repair work
  CLEANING        // Cleaning tasks
  EMERGENCY       // Emergency response
  MEETING         // Meetings
  OTHER           // Other tasks
}

enum TaskStatus {
  PENDING         // Not started
  IN_PROGRESS     // Currently working on
  COMPLETED       // Finished
  SKIPPED         // Skipped/postponed
  CANCELLED       // Cancelled
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  tenantId      Int
  role          Role
  refreshTokenHash String?
  notificationPreferences Json?
  phone            String?
  pushToken        String?
  createdAt     DateTime @default(now())
  resident      Resident?
  assignedTickets Ticket[] @relation("TicketAssignee")
  supplier      Supplier?
  impersonationEvents ImpersonationEvent[] @relation("MasterEvents")
  uploadedDocuments  Document[] @relation("UploadedDocuments")
  notifications      Notification[] @relation("UserNotifications")
  sentCommunications Communication[] @relation("CommunicationSender")
  receivedCommunications Communication[] @relation("CommunicationRecipient")
  maintenanceAssignments MaintenanceSchedule[] @relation("MaintenanceAssignments")
  maintenanceTeamMemberships MaintenanceTeamMember[]
  performedMaintenance MaintenanceHistory[] @relation("MaintenanceHistoryPerformer")
  verifiedMaintenance MaintenanceHistory[] @relation("MaintenanceHistoryVerifier")
  verifiedMaintenanceSchedules MaintenanceSchedule[] @relation("MaintenanceVerifications")
  approvedWorkOrders WorkOrder[] @relation("WorkOrderApprover")
  approvedExpenses  Expense[]   @relation("ExpenseApprover")
  documentShares    DocumentShare[] @relation("DocumentShares")
  ticketComments    TicketComment[] @relation("TicketCommentAuthor")
  createdBuildingCodes BuildingCode[] @relation("BuildingCodeCreator")
  createdVotes      Vote[]          @relation("VoteCreator")
  voteResponses     VoteResponse[]
  createdSchedules  WorkSchedule[]  @relation("ScheduleCreator")
  assignedTasks     ScheduledTask[] @relation("TaskAssignee")
  activityLogs      ActivityLog[]
  ownedContracts    Contract[]      @relation("ContractOwner")
  requestedApprovalTasks ApprovalTask[] @relation("ApprovalRequester")
  decidedApprovalTasks   ApprovalTask[] @relation("ApprovalDecider")
}

model Building {
  id        Int     @id @default(autoincrement())
  name      String
  address   String
  tenantId  Int
  units     Unit[]
  yearBuilt Int?
  floors    Int?
  totalUnits Int?
  area      Float?
  amenities String[]
  managerName String?
  contactEmail String?
  contactPhone String?
  notes     String?
  isActive  Boolean @default(true)
  maintenanceSchedules MaintenanceSchedule[]
  budgets   Budget[]
  expenses  Expense[]
  documents Document[]
  assets    Asset[]
  contracts Contract[]
  notifications Notification[]
  communications Communication[]
  codes     BuildingCode[]
  votes     Vote[]
  schedules WorkSchedule[]
  activityLogs ActivityLog[]
  approvalTasks ApprovalTask[]
}

model BuildingCode {
  id          Int      @id @default(autoincrement())
  buildingId  Int
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  codeType    CodeType @default(ENTRANCE)
  code        String   // The actual code/password
  description String?  // e.g., "Main entrance", "Service entrance", "Elevator"
  isActive    Boolean  @default(true)
  validFrom   DateTime @default(now())
  validUntil  DateTime?
  createdBy   Int?
  creator     User?    @relation("BuildingCodeCreator", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([buildingId])
  @@index([isActive])
}

model Unit {
  id         Int        @id @default(autoincrement())
  number     String
  buildingId Int
  building   Building   @relation(fields: [buildingId], references: [id])
  residents  Resident[]
  assets     Asset[]
  tickets    Ticket[]
  area       Float?
  bedrooms   Int?
  bathrooms  Int?
  parkingSpaces Int?
  floor      Int?
  isActive   Boolean @default(true)
  documents  Document[]
  communications Communication[]
}

model Resident {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id])
  units   Unit[]
  invoices Invoice[]
  recurringInvoices RecurringInvoice[]
  paymentMethods PaymentMethod[]
  activityLogs ActivityLog[]
  approvalTasks ApprovalTask[]
}

model Ticket {
  id           Int            @id @default(autoincrement())
  unitId       Int
  unit         Unit           @relation(fields: [unitId], references: [id])
  severity     TicketSeverity
  status       TicketStatus   @default(OPEN)
  slaDue       DateTime?
  photos       String[]
  assignedToId Int?
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  createdAt    DateTime       @default(now())
  workOrders   WorkOrder[]
  comments     TicketComment[]
  scheduledTasks ScheduledTask[]
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation("TicketCommentAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  skills    String[]
  rating    Float?
  documents String[]
  contactName String?
  email     String?
  phone     String?
  isActive  Boolean   @default(true)
  insuranceExpiry DateTime?
  complianceDocumentExpiry DateTime?
  lastComplianceReminderAt DateTime?
  complianceNotes String?
  userId    Int?      @unique
  user      User?     @relation(fields: [userId], references: [id])
  workOrders WorkOrder[]
  contracts Contract[]
}

model WorkOrder {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  supplierId   Int
  costEstimate Float?
  laborCost    Float?
  materialCost Float?
  equipmentCost Float?
  tax          Float?
  totalCost    Float?
  costNotes    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       WorkOrderStatus @default(PENDING)
  approvedById Int?
  approvedBy   User?    @relation("WorkOrderApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  scheduledStart DateTime?
  scheduledEnd DateTime?
  completedAt  DateTime?
  photos       String[]
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  scheduledTasks ScheduledTask[]
}

enum InvoiceStatus {
  UNPAID
  PAID
}

enum InvoiceReminderState {
  NONE
  UPCOMING
  SENT
  PROMISED
  ESCALATED
}

enum CollectionStatus {
  CURRENT
  PAST_DUE
  IN_COLLECTIONS
  PROMISE_TO_PAY
  RESOLVED
}

model Invoice {
  id         Int           @id @default(autoincrement())
  residentId Int
  resident   Resident      @relation(fields: [residentId], references: [id])
  items      Json
  amount     Float
  status     InvoiceStatus @default(UNPAID)
  dueDate    DateTime?
  lateFeeAmount Float      @default(0)
  reminderState InvoiceReminderState @default(NONE)
  collectionStatus CollectionStatus @default(CURRENT)
  promiseToPayDate DateTime?
  collectionNotes String?
  lastReminderAt DateTime?
  createdAt  DateTime      @default(now())
  paymentIntents PaymentIntent[]
  ledgerEntries LedgerEntry[]
}

model RecurringInvoice {
  id           Int      @id @default(autoincrement())
  residentId   Int
  resident     Resident @relation(fields: [residentId], references: [id])
  title        String?
  items        Json
  amount       Float
  recurrence   String   // e.g., "monthly", "quarterly", or cronstr
  dueDaysAfterIssue Int @default(30)
  graceDays    Int      @default(0)
  lateFeeAmount Float   @default(0)
  nextRunAt    DateTime
  lastRunAt    DateTime?
  active       Boolean  @default(true)
  pausedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ImpersonationEvent {
  id           Int      @id @default(autoincrement())
  masterUserId Int
  masterUser   User     @relation("MasterEvents", fields: [masterUserId], references: [id])
  action       String
  targetRole   Role?
  tenantId     Int?
  reason       String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model MaintenanceSchedule {
  id             Int                 @id @default(autoincrement())
  buildingId     Int
  building       Building            @relation(fields: [buildingId], references: [id])
  assetId        Int?
  asset          Asset?              @relation(fields: [assetId], references: [id])
  title          String
  description    String?
  category       MaintenanceCategory
  type           MaintenanceType
  frequency      String
  recurrenceRule String?
  startDate      DateTime
  nextOccurrence DateTime?
  assignedToId   Int?
  assignedTo     User?               @relation("MaintenanceAssignments", fields: [assignedToId], references: [id])
  priority       MaintenancePriority @default(MEDIUM)
  estimatedCost  Float?
  lastCompleted  DateTime?
  completionNotes String?
  completionVerified Boolean @default(false)
  verifiedById   Int?
  verifiedBy     User?               @relation("MaintenanceVerifications", fields: [verifiedById], references: [id])
  verifiedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  communications Communication[]
  teamMembers    MaintenanceTeamMember[]
  histories      MaintenanceHistory[]
}

model Budget {
  id          Int           @id @default(autoincrement())
  buildingId  Int
  building    Building      @relation(fields: [buildingId], references: [id])
  name        String
  year        Int
  amount      Float
  actualSpent Float         @default(0)
  status      BudgetStatus  @default(PLANNED)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  expenses    Expense[]
}

model Expense {
  id          Int             @id @default(autoincrement())
  buildingId  Int
  building    Building        @relation(fields: [buildingId], references: [id])
  budgetId    Int?
  budget      Budget?         @relation(fields: [budgetId], references: [id])
  category    ExpenseCategory
  amount      Float
  description String?
  incurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  documents   Document[]
  status      ExpenseStatus   @default(PENDING)
  approvedById Int?
  approvedBy  User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedAt  DateTime?
}

model Document {
  id           Int       @id @default(autoincrement())
  buildingId   Int?
  building     Building? @relation(fields: [buildingId], references: [id])
  unitId       Int?
  unit         Unit?     @relation(fields: [unitId], references: [id])
  contractId   Int?
  contract     Contract? @relation("ContractDocuments", fields: [contractId], references: [id])
  assetId      Int?
  asset        Asset?    @relation("AssetDocuments", fields: [assetId], references: [id])
  expenseId    Int?
  expense      Expense?  @relation(fields: [expenseId], references: [id])
  uploadedById Int?
  uploadedBy   User?     @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  name         String
  url          String
  category     String?
  uploadedAt   DateTime  @default(now())
  // Enhanced fields for Sprint 5
  description  String?
  tags         String[]
  fileSize     Int?
  mimeType     String?
  version      Int       @default(1)
  isLatest     Boolean   @default(true)
  parentId     Int?
  parent       Document? @relation("DocumentVersions", fields: [parentId], references: [id])
  versions     Document[] @relation("DocumentVersions")
  accessLevel  DocumentAccessLevel @default(PRIVATE)
  sharedWith   DocumentShare[]
  updatedAt    DateTime  @updatedAt
}

enum DocumentAccessLevel {
  PUBLIC
  PRIVATE
  RESTRICTED
}

model DocumentShare {
  id         Int      @id @default(autoincrement())
  documentId Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation("DocumentShares", fields: [userId], references: [id], onDelete: Cascade)
  permission DocumentPermission @default(VIEW)
  sharedAt   DateTime @default(now())
  expiresAt  DateTime?
  
  @@unique([documentId, userId])
}

enum DocumentPermission {
  VIEW
  DOWNLOAD
  EDIT
  DELETE
}

model Notification {
  id         Int       @id @default(autoincrement())
  tenantId   Int?
  userId     Int?
  buildingId Int?
  title      String
  message    String
  type       String?
  metadata   Json?
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation("UserNotifications", fields: [userId], references: [id])
  building   Building? @relation(fields: [buildingId], references: [id])
}

enum ActivitySeverity {
  INFO
  WARNING
  CRITICAL
}

enum ApprovalTaskType {
  EXPENSE_APPROVAL
  WORK_ORDER_APPROVAL
  DOCUMENT_DELETE
  RESIDENT_BALANCE_ADJUSTMENT
  BUDGET_OVERRUN
}

enum ApprovalTaskStatus {
  PENDING
  APPROVED
  REJECTED
}

model ActivityLog {
  id          Int              @id @default(autoincrement())
  userId      Int?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  buildingId  Int?
  building    Building?        @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  residentId  Int?
  resident    Resident?        @relation(fields: [residentId], references: [id], onDelete: SetNull)
  entityType  String
  entityId    Int?
  action      String
  summary     String
  severity    ActivitySeverity @default(INFO)
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([entityType, entityId])
  @@index([buildingId, createdAt])
  @@index([residentId, createdAt])
  @@index([createdAt])
}

model ApprovalTask {
  id            Int                @id @default(autoincrement())
  type          ApprovalTaskType
  status        ApprovalTaskStatus @default(PENDING)
  entityType    String
  entityId      Int?
  buildingId    Int?
  building      Building?          @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  residentId    Int?
  resident      Resident?          @relation(fields: [residentId], references: [id], onDelete: SetNull)
  requestedById Int?
  requestedBy   User?              @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  decidedById   Int?
  decidedBy     User?              @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  title         String
  description   String?
  reason        String?
  metadata      Json?
  decidedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, type, createdAt])
  @@index([entityType, entityId])
  @@index([buildingId, status])
}

model Contract {
  id          Int        @id @default(autoincrement())
  buildingId  Int
  building    Building   @relation(fields: [buildingId], references: [id])
  supplierId  Int?
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
  ownerUserId Int?
  owner       User?      @relation("ContractOwner", fields: [ownerUserId], references: [id])
  title       String
  description String?
  value       Float?
  startDate   DateTime
  endDate     DateTime?
  status      String     @default("ACTIVE")
  renewalReminderDays Int @default(30)
  lastRenewalReminderAt DateTime?
  approvalStatus String   @default("APPROVED")
  approvedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  documents   Document[] @relation("ContractDocuments")
}

model Asset {
  id          Int                 @id @default(autoincrement())
  buildingId  Int
  building    Building            @relation(fields: [buildingId], references: [id])
  unitId      Int?
  unit        Unit?               @relation(fields: [unitId], references: [id])
  name        String
  category    MaintenanceCategory
  description String?
  serialNumber String?
  location    String?
  purchaseDate DateTime?
  warrantyExpiry DateTime?
  value       Float?
  salvageValue Float?
  quantity    Int                  @default(1)
  usefulLifeYears Int?
  depreciationMethod String?
  status      String?
  lastInventoryCheck DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  maintenanceSchedules MaintenanceSchedule[]
  documents   Document[]          @relation("AssetDocuments")
  maintenanceHistories MaintenanceHistory[]
  locationHistory AssetLocationHistory[]
}

model Communication {
  id            Int        @id @default(autoincrement())
  buildingId    Int?
  building      Building?  @relation(fields: [buildingId], references: [id])
  unitId        Int?
  unit          Unit?      @relation(fields: [unitId], references: [id])
  senderId      Int
  sender        User       @relation("CommunicationSender", fields: [senderId], references: [id])
  recipientId   Int?
  recipient     User?      @relation("CommunicationRecipient", fields: [recipientId], references: [id])
  maintenanceScheduleId Int?
  maintenanceSchedule   MaintenanceSchedule? @relation(fields: [maintenanceScheduleId], references: [id])
  subject       String?
  message       String
  channel       String?
  metadata      Json?
  readAt        DateTime?
  createdAt     DateTime   @default(now())
}

model MaintenanceTeamMember {
  scheduleId Int
  userId     Int
  role       String?
  assignedAt DateTime @default(now())
  schedule   MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([scheduleId, userId])
}

model MaintenanceHistory {
  id            Int      @id @default(autoincrement())
  scheduleId    Int
  schedule      MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assetId       Int?
  asset         Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  performedAt   DateTime
  notes         String?
  cost          Float?
  performedById Int?
  performedBy   User?   @relation("MaintenanceHistoryPerformer", fields: [performedById], references: [id])
  verified      Boolean @default(false)
  verifiedById  Int?
  verifiedBy    User?   @relation("MaintenanceHistoryVerifier", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?
  verificationNotes String?
  createdAt     DateTime @default(now())
}

model AssetLocationHistory {
  id        Int      @id @default(autoincrement())
  assetId   Int
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  location  String
  notes     String?
  changedAt DateTime @default(now())
}

// =======================
// Sprint 6: Payments Models
// =======================

enum PaymentIntentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  PROCESSING
  SUCCEEDED
  CANCELED
  REQUIRES_ACTION
  FAILED
}

model PaymentMethod {
  id           Int      @id @default(autoincrement())
  residentId   Int
  resident     Resident @relation(fields: [residentId], references: [id])
  provider     String   // tranzila | stripe
  token        String   // provider tokenized reference
  brand        String?
  last4        String?
  expMonth     Int?
  expYear      Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  paymentIntents PaymentIntent[]
}

model PaymentIntent {
  id            Int                 @id @default(autoincrement())
  invoiceId     Int
  invoice       Invoice             @relation(fields: [invoiceId], references: [id])
  amount        Float
  currency      String              @default("NIS")
  status        PaymentIntentStatus @default(REQUIRES_PAYMENT_METHOD)
  provider      String              // tranzila | stripe
  providerIntentId String?          // provider reference
  clientSecret  String?             // for client-side confirmation if needed
  paymentMethodId Int?
  paymentMethod PaymentMethod?      @relation(fields: [paymentMethodId], references: [id])
  idempotencyKey String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  refunds       Refund[]
  transactions  ProviderTransaction[]
  ledgerEntries LedgerEntry[]
}

model Refund {
  id           Int           @id @default(autoincrement())
  paymentIntentId Int
  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  amount       Float
  reason       String?
  providerRefundId String?
  createdAt    DateTime      @default(now())
}

model ProviderTransaction {
  id              Int           @id @default(autoincrement())
  paymentIntentId Int
  paymentIntent   PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  provider        String
  type            String        // authorization | capture | refund | webhook
  status          String?
  code            String?
  raw             Json?
  createdAt       DateTime      @default(now())
}

model WebhookEvent {
  id         Int      @id @default(autoincrement())
  provider   String
  eventId    String
  signature  String?
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([provider, eventId])
}

// Simple double-entry style ledger entries
model LedgerEntry {
  id          Int      @id @default(autoincrement())
  invoiceId   Int?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  paymentIntentId Int?
  paymentIntent   PaymentIntent? @relation(fields: [paymentIntentId], references: [id])
  entryType   String   // payment | fee | refund | net | adjustment
  amount      Float
  debit       String   // account name
  credit      String   // account name
  createdAt   DateTime @default(now())
}

// =======================
// Sprint 5: Voting System Models
// =======================

model Vote {
  id          Int          @id @default(autoincrement())
  buildingId  Int
  building    Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  title       String
  description String?
  question    String       // The actual question being voted on
  voteType    VoteType     @default(YES_NO)
  options     VoteOption[] // For multiple choice votes
  createdBy   Int
  creator     User         @relation("VoteCreator", fields: [createdBy], references: [id])
  startDate   DateTime     @default(now())
  endDate     DateTime     // Voting deadline
  isActive    Boolean      @default(true)
  isClosed    Boolean      @default(false)
  requireAllVotes Boolean  @default(false) // Whether all tenants must vote
  responses   VoteResponse[]
  results     Json?        // Cached results
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([buildingId])
  @@index([isActive])
  @@index([endDate])
}

model VoteOption {
  id          Int            @id @default(autoincrement())
  voteId      Int
  vote        Vote           @relation(fields: [voteId], references: [id], onDelete: Cascade)
  optionText  String
  order       Int            @default(0)
  responses   VoteResponse[]
  
  @@index([voteId])
}

model VoteResponse {
  id          Int         @id @default(autoincrement())
  voteId      Int
  vote        Vote        @relation(fields: [voteId], references: [id], onDelete: Cascade)
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  optionId    Int?        // For multiple choice
  option      VoteOption? @relation(fields: [optionId], references: [id])
  response    Boolean?    // For YES_NO votes
  rating      Int?        // For RATING votes (1-5)
  comment     String?     // Optional comment
  votedAt     DateTime    @default(now())
  
  @@unique([voteId, userId]) // Each user can only vote once
  @@index([voteId])
  @@index([userId])
}

// =======================
// Sprint 6: Work Schedule Models
// =======================

model WorkSchedule {
  id          Int                @id @default(autoincrement())
  date        DateTime           // The schedule date
  buildingId  Int?
  building    Building?          @relation(fields: [buildingId], references: [id])
  title       String?            // e.g., "Daily Rounds", "Emergency Repairs"
  description String?
  createdBy   Int
  creator     User               @relation("ScheduleCreator", fields: [createdBy], references: [id])
  tasks       ScheduledTask[]
  status      ScheduleStatus     @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  @@index([date])
  @@index([buildingId])
  @@index([status])
}

model ScheduledTask {
  id             Int            @id @default(autoincrement())
  scheduleId     Int
  schedule       WorkSchedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assignedTo     Int?
  assignee       User?          @relation("TaskAssignee", fields: [assignedTo], references: [id])
  taskType       TaskType       @default(MAINTENANCE)
  title          String
  description    String?
  location       String?        // Building/unit location
  estimatedTime  Int?           // In minutes
  priority       Priority       @default(MEDIUM)
  status         TaskStatus     @default(PENDING)
  startTime      DateTime?      // Planned start time
  endTime        DateTime?      // Planned end time
  actualStart    DateTime?      // Actual start time
  actualEnd      DateTime?      // Actual completion time
  notes          String?        // Completion notes
  ticketId       Int?           // Link to related ticket
  ticket         Ticket?        @relation(fields: [ticketId], references: [id])
  workOrderId    Int?           // Link to related work order
  workOrder      WorkOrder?     @relation(fields: [workOrderId], references: [id])
  order          Int            @default(0) // Order in schedule
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  @@index([scheduleId])
  @@index([assignedTo])
  @@index([status])
  @@index([taskType])
}
