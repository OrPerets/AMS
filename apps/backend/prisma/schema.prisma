datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PM
  TECH
  RESIDENT
  ACCOUNTANT
  MASTER
}

enum MaintenanceCategory {
  GENERAL
  HVAC
  ELECTRICAL
  PLUMBING
  SAFETY
  LANDSCAPING
  ELEVATORS
}

enum MaintenanceType {
  PREVENTIVE
  INSPECTION
  CORRECTIVE
  EMERGENCY
}

enum TicketSeverity {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum BudgetStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  STAFF
  ADMINISTRATION
  OTHER
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  tenantId      Int
  role          Role
  refreshTokenHash String?
  createdAt     DateTime @default(now())
  resident      Resident?
  assignedTickets Ticket[] @relation("TicketAssignee")
  supplier      Supplier?
  impersonationEvents ImpersonationEvent[] @relation("MasterEvents")
  uploadedDocuments  Document[] @relation("UploadedDocuments")
  notifications      Notification[] @relation("UserNotifications")
  sentCommunications Communication[] @relation("CommunicationSender")
  receivedCommunications Communication[] @relation("CommunicationRecipient")
  maintenanceAssignments MaintenanceSchedule[] @relation("MaintenanceAssignments")
}

model Building {
  id        Int     @id @default(autoincrement())
  name      String
  address   String
  tenantId  Int
  units     Unit[]
  yearBuilt Int?
  floors    Int?
  totalUnits Int?
  area      Float?
  amenities String[]
  managerName String?
  contactEmail String?
  contactPhone String?
  notes     String?
  maintenanceSchedules MaintenanceSchedule[]
  budgets   Budget[]
  expenses  Expense[]
  documents Document[]
  assets    Asset[]
  contracts Contract[]
  notifications Notification[]
  communications Communication[]
}

model Unit {
  id         Int        @id @default(autoincrement())
  number     String
  buildingId Int
  building   Building   @relation(fields: [buildingId], references: [id])
  residents  Resident[]
  tickets    Ticket[]
  area       Float?
  bedrooms   Int?
  bathrooms  Int?
  parkingSpaces Int?
  floor      Int?
  documents  Document[]
  communications Communication[]
}

model Resident {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id])
  units   Unit[]
  invoices Invoice[]
}

model Ticket {
  id           Int            @id @default(autoincrement())
  unitId       Int
  unit         Unit           @relation(fields: [unitId], references: [id])
  severity     TicketSeverity
  status       TicketStatus   @default(OPEN)
  slaDue       DateTime?
  photos       String[]
  assignedToId Int?
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  createdAt    DateTime       @default(now())
  workOrders   WorkOrder[]
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  skills    String[]
  rating    Float?
  documents String[]
  userId    Int?      @unique
  user      User?     @relation(fields: [userId], references: [id])
  workOrders WorkOrder[]
  contracts Contract[]
}

model WorkOrder {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  supplierId   Int
  costEstimate Float?
  createdAt    DateTime @default(now())
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  supplier     Supplier @relation(fields: [supplierId], references: [id])
}

enum InvoiceStatus {
  UNPAID
  PAID
}

model Invoice {
  id         Int           @id @default(autoincrement())
  residentId Int
  resident   Resident      @relation(fields: [residentId], references: [id])
  items      Json
  amount     Float
  status     InvoiceStatus @default(UNPAID)
  createdAt  DateTime      @default(now())
}

model ImpersonationEvent {
  id           Int      @id @default(autoincrement())
  masterUserId Int
  masterUser   User     @relation("MasterEvents", fields: [masterUserId], references: [id])
  action       String
  targetRole   Role?
  tenantId     Int?
  reason       String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model MaintenanceSchedule {
  id             Int                 @id @default(autoincrement())
  buildingId     Int
  building       Building            @relation(fields: [buildingId], references: [id])
  assetId        Int?
  asset          Asset?              @relation(fields: [assetId], references: [id])
  title          String
  description    String?
  category       MaintenanceCategory
  type           MaintenanceType
  frequency      String
  startDate      DateTime
  nextOccurrence DateTime?
  assignedToId   Int?
  assignedTo     User?               @relation("MaintenanceAssignments", fields: [assignedToId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  communications Communication[]
}

model Budget {
  id          Int           @id @default(autoincrement())
  buildingId  Int
  building    Building      @relation(fields: [buildingId], references: [id])
  name        String
  year        Int
  amount      Float
  actualSpent Float         @default(0)
  status      BudgetStatus  @default(PLANNED)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  expenses    Expense[]
}

model Expense {
  id          Int             @id @default(autoincrement())
  buildingId  Int
  building    Building        @relation(fields: [buildingId], references: [id])
  budgetId    Int?
  budget      Budget?         @relation(fields: [budgetId], references: [id])
  category    ExpenseCategory
  amount      Float
  description String?
  incurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  documents   Document[]
}

model Document {
  id           Int       @id @default(autoincrement())
  buildingId   Int?
  building     Building? @relation(fields: [buildingId], references: [id])
  unitId       Int?
  unit         Unit?     @relation(fields: [unitId], references: [id])
  contractId   Int?
  contract     Contract? @relation("ContractDocuments", fields: [contractId], references: [id])
  assetId      Int?
  asset        Asset?    @relation("AssetDocuments", fields: [assetId], references: [id])
  expenseId    Int?
  expense      Expense?  @relation(fields: [expenseId], references: [id])
  uploadedById Int?
  uploadedBy   User?     @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  name         String
  url          String
  category     String?
  uploadedAt   DateTime  @default(now())
}

model Notification {
  id         Int       @id @default(autoincrement())
  tenantId   Int?
  userId     Int?
  buildingId Int?
  title      String
  message    String
  type       String?
  metadata   Json?
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation("UserNotifications", fields: [userId], references: [id])
  building   Building? @relation(fields: [buildingId], references: [id])
}

model Contract {
  id          Int        @id @default(autoincrement())
  buildingId  Int
  building    Building   @relation(fields: [buildingId], references: [id])
  supplierId  Int?
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
  title       String
  description String?
  value       Float?
  startDate   DateTime
  endDate     DateTime?
  status      String     @default("ACTIVE")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  documents   Document[] @relation("ContractDocuments")
}

model Asset {
  id          Int                 @id @default(autoincrement())
  buildingId  Int
  building    Building            @relation(fields: [buildingId], references: [id])
  name        String
  category    MaintenanceCategory
  description String?
  serialNumber String?
  location    String?
  purchaseDate DateTime?
  warrantyExpiry DateTime?
  value       Float?
  status      String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  maintenanceSchedules MaintenanceSchedule[]
  documents   Document[]          @relation("AssetDocuments")
}

model Communication {
  id            Int        @id @default(autoincrement())
  buildingId    Int?
  building      Building?  @relation(fields: [buildingId], references: [id])
  unitId        Int?
  unit          Unit?      @relation(fields: [unitId], references: [id])
  senderId      Int
  sender        User       @relation("CommunicationSender", fields: [senderId], references: [id])
  recipientId   Int?
  recipient     User?      @relation("CommunicationRecipient", fields: [recipientId], references: [id])
  maintenanceScheduleId Int?
  maintenanceSchedule   MaintenanceSchedule? @relation(fields: [maintenanceScheduleId], references: [id])
  subject       String?
  message       String
  channel       String?
  metadata      Json?
  readAt        DateTime?
  createdAt     DateTime   @default(now())
}
