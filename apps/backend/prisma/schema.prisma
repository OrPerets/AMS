datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PM
  TECH
  RESIDENT
  ACCOUNTANT
  MASTER
}

enum MaintenanceCategory {
  GENERAL
  HVAC
  ELECTRICAL
  PLUMBING
  SAFETY
  LANDSCAPING
  ELEVATORS
}

enum MaintenanceType {
  PREVENTIVE
  INSPECTION
  CORRECTIVE
  EMERGENCY
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketSeverity {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum WorkOrderStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  INVOICED
}

enum BudgetStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  STAFF
  ADMINISTRATION
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  tenantId      Int
  role          Role
  refreshTokenHash String?
  notificationPreferences Json?
  phone            String?
  pushToken        String?
  createdAt     DateTime @default(now())
  resident      Resident?
  assignedTickets Ticket[] @relation("TicketAssignee")
  supplier      Supplier?
  impersonationEvents ImpersonationEvent[] @relation("MasterEvents")
  uploadedDocuments  Document[] @relation("UploadedDocuments")
  notifications      Notification[] @relation("UserNotifications")
  sentCommunications Communication[] @relation("CommunicationSender")
  receivedCommunications Communication[] @relation("CommunicationRecipient")
  maintenanceAssignments MaintenanceSchedule[] @relation("MaintenanceAssignments")
  maintenanceTeamMemberships MaintenanceTeamMember[]
  performedMaintenance MaintenanceHistory[] @relation("MaintenanceHistoryPerformer")
  verifiedMaintenance MaintenanceHistory[] @relation("MaintenanceHistoryVerifier")
  verifiedMaintenanceSchedules MaintenanceSchedule[] @relation("MaintenanceVerifications")
  approvedWorkOrders WorkOrder[] @relation("WorkOrderApprover")
  approvedExpenses  Expense[]   @relation("ExpenseApprover")
  documentShares    DocumentShare[] @relation("DocumentShares")
  ticketComments    TicketComment[] @relation("TicketCommentAuthor")
}

model Building {
  id        Int     @id @default(autoincrement())
  name      String
  address   String
  tenantId  Int
  units     Unit[]
  yearBuilt Int?
  floors    Int?
  totalUnits Int?
  area      Float?
  amenities String[]
  managerName String?
  contactEmail String?
  contactPhone String?
  notes     String?
  maintenanceSchedules MaintenanceSchedule[]
  budgets   Budget[]
  expenses  Expense[]
  documents Document[]
  assets    Asset[]
  contracts Contract[]
  notifications Notification[]
  communications Communication[]
}

model Unit {
  id         Int        @id @default(autoincrement())
  number     String
  buildingId Int
  building   Building   @relation(fields: [buildingId], references: [id])
  residents  Resident[]
  tickets    Ticket[]
  area       Float?
  bedrooms   Int?
  bathrooms  Int?
  parkingSpaces Int?
  floor      Int?
  documents  Document[]
  communications Communication[]
}

model Resident {
  id      Int    @id @default(autoincrement())
  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id])
  units   Unit[]
  invoices Invoice[]
  recurringInvoices RecurringInvoice[]
  paymentMethods PaymentMethod[]
}

model Ticket {
  id           Int            @id @default(autoincrement())
  unitId       Int
  unit         Unit           @relation(fields: [unitId], references: [id])
  severity     TicketSeverity
  status       TicketStatus   @default(OPEN)
  slaDue       DateTime?
  photos       String[]
  assignedToId Int?
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  createdAt    DateTime       @default(now())
  workOrders   WorkOrder[]
  comments     TicketComment[]
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation("TicketCommentAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  skills    String[]
  rating    Float?
  documents String[]
  userId    Int?      @unique
  user      User?     @relation(fields: [userId], references: [id])
  workOrders WorkOrder[]
  contracts Contract[]
}

model WorkOrder {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  supplierId   Int
  costEstimate Float?
  laborCost    Float?
  materialCost Float?
  equipmentCost Float?
  tax          Float?
  totalCost    Float?
  costNotes    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       WorkOrderStatus @default(PENDING)
  approvedById Int?
  approvedBy   User?    @relation("WorkOrderApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  scheduledStart DateTime?
  scheduledEnd DateTime?
  completedAt  DateTime?
  photos       String[]
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  supplier     Supplier @relation(fields: [supplierId], references: [id])
}

enum InvoiceStatus {
  UNPAID
  PAID
}

model Invoice {
  id         Int           @id @default(autoincrement())
  residentId Int
  resident   Resident      @relation(fields: [residentId], references: [id])
  items      Json
  amount     Float
  status     InvoiceStatus @default(UNPAID)
  createdAt  DateTime      @default(now())
  paymentIntents PaymentIntent[]
  ledgerEntries LedgerEntry[]
}

model RecurringInvoice {
  id           Int      @id @default(autoincrement())
  residentId   Int
  resident     Resident @relation(fields: [residentId], references: [id])
  items        Json
  amount       Float
  recurrence   String   // e.g., "monthly", "quarterly", or cronstr
  nextRunAt    DateTime
  lastRunAt    DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ImpersonationEvent {
  id           Int      @id @default(autoincrement())
  masterUserId Int
  masterUser   User     @relation("MasterEvents", fields: [masterUserId], references: [id])
  action       String
  targetRole   Role?
  tenantId     Int?
  reason       String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model MaintenanceSchedule {
  id             Int                 @id @default(autoincrement())
  buildingId     Int
  building       Building            @relation(fields: [buildingId], references: [id])
  assetId        Int?
  asset          Asset?              @relation(fields: [assetId], references: [id])
  title          String
  description    String?
  category       MaintenanceCategory
  type           MaintenanceType
  frequency      String
  recurrenceRule String?
  startDate      DateTime
  nextOccurrence DateTime?
  assignedToId   Int?
  assignedTo     User?               @relation("MaintenanceAssignments", fields: [assignedToId], references: [id])
  priority       MaintenancePriority @default(MEDIUM)
  estimatedCost  Float?
  lastCompleted  DateTime?
  completionNotes String?
  completionVerified Boolean @default(false)
  verifiedById   Int?
  verifiedBy     User?               @relation("MaintenanceVerifications", fields: [verifiedById], references: [id])
  verifiedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  communications Communication[]
  teamMembers    MaintenanceTeamMember[]
  histories      MaintenanceHistory[]
}

model Budget {
  id          Int           @id @default(autoincrement())
  buildingId  Int
  building    Building      @relation(fields: [buildingId], references: [id])
  name        String
  year        Int
  amount      Float
  actualSpent Float         @default(0)
  status      BudgetStatus  @default(PLANNED)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  expenses    Expense[]
}

model Expense {
  id          Int             @id @default(autoincrement())
  buildingId  Int
  building    Building        @relation(fields: [buildingId], references: [id])
  budgetId    Int?
  budget      Budget?         @relation(fields: [budgetId], references: [id])
  category    ExpenseCategory
  amount      Float
  description String?
  incurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  documents   Document[]
  status      ExpenseStatus   @default(PENDING)
  approvedById Int?
  approvedBy  User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedAt  DateTime?
}

model Document {
  id           Int       @id @default(autoincrement())
  buildingId   Int?
  building     Building? @relation(fields: [buildingId], references: [id])
  unitId       Int?
  unit         Unit?     @relation(fields: [unitId], references: [id])
  contractId   Int?
  contract     Contract? @relation("ContractDocuments", fields: [contractId], references: [id])
  assetId      Int?
  asset        Asset?    @relation("AssetDocuments", fields: [assetId], references: [id])
  expenseId    Int?
  expense      Expense?  @relation(fields: [expenseId], references: [id])
  uploadedById Int?
  uploadedBy   User?     @relation("UploadedDocuments", fields: [uploadedById], references: [id])
  name         String
  url          String
  category     String?
  uploadedAt   DateTime  @default(now())
  // Enhanced fields for Sprint 5
  description  String?
  tags         String[]
  fileSize     Int?
  mimeType     String?
  version      Int       @default(1)
  isLatest     Boolean   @default(true)
  parentId     Int?
  parent       Document? @relation("DocumentVersions", fields: [parentId], references: [id])
  versions     Document[] @relation("DocumentVersions")
  accessLevel  DocumentAccessLevel @default(PRIVATE)
  sharedWith   DocumentShare[]
  updatedAt    DateTime  @updatedAt
}

enum DocumentAccessLevel {
  PUBLIC
  PRIVATE
  RESTRICTED
}

model DocumentShare {
  id         Int      @id @default(autoincrement())
  documentId Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation("DocumentShares", fields: [userId], references: [id], onDelete: Cascade)
  permission DocumentPermission @default(VIEW)
  sharedAt   DateTime @default(now())
  expiresAt  DateTime?
  
  @@unique([documentId, userId])
}

enum DocumentPermission {
  VIEW
  DOWNLOAD
  EDIT
  DELETE
}

model Notification {
  id         Int       @id @default(autoincrement())
  tenantId   Int?
  userId     Int?
  buildingId Int?
  title      String
  message    String
  type       String?
  metadata   Json?
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation("UserNotifications", fields: [userId], references: [id])
  building   Building? @relation(fields: [buildingId], references: [id])
}

model Contract {
  id          Int        @id @default(autoincrement())
  buildingId  Int
  building    Building   @relation(fields: [buildingId], references: [id])
  supplierId  Int?
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
  title       String
  description String?
  value       Float?
  startDate   DateTime
  endDate     DateTime?
  status      String     @default("ACTIVE")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  documents   Document[] @relation("ContractDocuments")
}

model Asset {
  id          Int                 @id @default(autoincrement())
  buildingId  Int
  building    Building            @relation(fields: [buildingId], references: [id])
  name        String
  category    MaintenanceCategory
  description String?
  serialNumber String?
  location    String?
  purchaseDate DateTime?
  warrantyExpiry DateTime?
  value       Float?
  salvageValue Float?
  quantity    Int                  @default(1)
  usefulLifeYears Int?
  depreciationMethod String?
  status      String?
  lastInventoryCheck DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  maintenanceSchedules MaintenanceSchedule[]
  documents   Document[]          @relation("AssetDocuments")
  maintenanceHistories MaintenanceHistory[]
  locationHistory AssetLocationHistory[]
}

model Communication {
  id            Int        @id @default(autoincrement())
  buildingId    Int?
  building      Building?  @relation(fields: [buildingId], references: [id])
  unitId        Int?
  unit          Unit?      @relation(fields: [unitId], references: [id])
  senderId      Int
  sender        User       @relation("CommunicationSender", fields: [senderId], references: [id])
  recipientId   Int?
  recipient     User?      @relation("CommunicationRecipient", fields: [recipientId], references: [id])
  maintenanceScheduleId Int?
  maintenanceSchedule   MaintenanceSchedule? @relation(fields: [maintenanceScheduleId], references: [id])
  subject       String?
  message       String
  channel       String?
  metadata      Json?
  readAt        DateTime?
  createdAt     DateTime   @default(now())
}

model MaintenanceTeamMember {
  scheduleId Int
  userId     Int
  role       String?
  assignedAt DateTime @default(now())
  schedule   MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([scheduleId, userId])
}

model MaintenanceHistory {
  id            Int      @id @default(autoincrement())
  scheduleId    Int
  schedule      MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assetId       Int?
  asset         Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  performedAt   DateTime
  notes         String?
  cost          Float?
  performedById Int?
  performedBy   User?   @relation("MaintenanceHistoryPerformer", fields: [performedById], references: [id])
  verified      Boolean @default(false)
  verifiedById  Int?
  verifiedBy    User?   @relation("MaintenanceHistoryVerifier", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?
  verificationNotes String?
  createdAt     DateTime @default(now())
}

model AssetLocationHistory {
  id        Int      @id @default(autoincrement())
  assetId   Int
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  location  String
  notes     String?
  changedAt DateTime @default(now())
}

// =======================
// Sprint 6: Payments Models
// =======================

enum PaymentIntentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  PROCESSING
  SUCCEEDED
  CANCELED
  REQUIRES_ACTION
  FAILED
}

model PaymentMethod {
  id           Int      @id @default(autoincrement())
  residentId   Int
  resident     Resident @relation(fields: [residentId], references: [id])
  provider     String   // tranzila | stripe
  token        String   // provider tokenized reference
  brand        String?
  last4        String?
  expMonth     Int?
  expYear      Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  paymentIntents PaymentIntent[]
}

model PaymentIntent {
  id            Int                 @id @default(autoincrement())
  invoiceId     Int
  invoice       Invoice             @relation(fields: [invoiceId], references: [id])
  amount        Float
  currency      String              @default("NIS")
  status        PaymentIntentStatus @default(REQUIRES_PAYMENT_METHOD)
  provider      String              // tranzila | stripe
  providerIntentId String?          // provider reference
  clientSecret  String?             // for client-side confirmation if needed
  paymentMethodId Int?
  paymentMethod PaymentMethod?      @relation(fields: [paymentMethodId], references: [id])
  idempotencyKey String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  refunds       Refund[]
  transactions  ProviderTransaction[]
  ledgerEntries LedgerEntry[]
}

model Refund {
  id           Int           @id @default(autoincrement())
  paymentIntentId Int
  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  amount       Float
  reason       String?
  providerRefundId String?
  createdAt    DateTime      @default(now())
}

model ProviderTransaction {
  id              Int           @id @default(autoincrement())
  paymentIntentId Int
  paymentIntent   PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  provider        String
  type            String        // authorization | capture | refund | webhook
  status          String?
  code            String?
  raw             Json?
  createdAt       DateTime      @default(now())
}

model WebhookEvent {
  id         Int      @id @default(autoincrement())
  provider   String
  eventId    String
  signature  String?
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([provider, eventId])
}

// Simple double-entry style ledger entries
model LedgerEntry {
  id          Int      @id @default(autoincrement())
  invoiceId   Int?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  paymentIntentId Int?
  paymentIntent   PaymentIntent? @relation(fields: [paymentIntentId], references: [id])
  entryType   String   // payment | fee | refund | net | adjustment
  amount      Float
  debit       String   // account name
  credit      String   // account name
  createdAt   DateTime @default(now())
}
